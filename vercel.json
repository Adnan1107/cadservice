{
  "version": 2,
  "buildCommand": "python manage.py collectstatic --noinput",
  "outputDirectory": "staticfiles",
  "installCommand": "pip install -r requirements.txt",
  "framework": "django",
  "builds": [
    {
      "src": "creatus/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb",
        "runtime": "python3.9"
      }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "creatus/wsgi.py"
    }
  ]
}